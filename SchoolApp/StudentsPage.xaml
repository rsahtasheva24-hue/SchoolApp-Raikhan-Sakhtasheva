<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SchoolApp.StudentsPage"
             Title="Students List">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="School Students"
               FontSize="26"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Entry Text="{Binding NewStudentName}"
               Placeholder="Type student name here..."
               FontSize="16" />

        <Button Text="Add New Student"
                Clicked="OnAddStudentClicked"
                BackgroundColor="DarkBlue"
                TextColor="White" />

        <CollectionView ItemsSource="{Binding Students}" 
                        Margin="0,10,0,0" 
                        SelectionMode="Single" 
                        SelectionChanged="OnStudentSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="LightGray" 
                           CornerRadius="8" 
                           Padding="12" 
                           Margin="0,4" 
                           BackgroundColor="#F9F9F9">
                        <Label Text="{Binding}" 
                               FontSize="18" 
                               TextColor="Black" />
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>